#!/usr/bin/env bash
set -euo pipefail

FQDN="{{ nas_tailscale_fqdn }}"
CERT_SRC="/var/lib/tailscale/certs/${FQDN}.crt"
KEY_SRC="/var/lib/tailscale/certs/${FQDN}.key"
COCKPIT_DIR="/etc/cockpit/ws-certs.d"

tailscale cert \
  --cert-file "${CERT_SRC}" \
  --key-file "${KEY_SRC}" \
  "${FQDN}"

cp "${CERT_SRC}" "${COCKPIT_DIR}/9-tailscale.cert"
cp "${KEY_SRC}"  "${COCKPIT_DIR}/9-tailscale.key"
chmod 600 "${COCKPIT_DIR}/9-tailscale.key"

systemctl restart cockpit
